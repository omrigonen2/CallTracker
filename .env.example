# --- App ---
NODE_ENV=development
PORT=3000
# Public URL of the app (set to your Render URL in production)
APP_BASE_URL=http://localhost:3000

# --- Secrets ---
# 32-byte base64 (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))")
MASTER_ENCRYPTION_KEY=
JWT_SECRET=

# --- Datastores ---
MONGODB_URI=mongodb://localhost:27017/calltracker
# redis:// for local, rediss:// for TLS (e.g. Upstash on Render)
REDIS_URL=redis://localhost:6379

# --- Object storage (recordings) ---
S3_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Note: Telephony provider credentials (Twilio and Telnyx) are NOT configured here.
# They are managed by Super-Admin in the Admin Console UI.
# Mail (Resend) is also configured via Admin > System Settings.
