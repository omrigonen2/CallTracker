<%- include('../partials/header') %>

<div class="page-head">
  <div class="title-block">
    <h1><%= t('billing:title') %></h1>
    <p class="subtitle"><%= t('billing:subtitle') %></p>
  </div>
</div>

<div class="kpi-grid">
  <div class="kpi-card">
    <div class="kpi-card__head">
      <span class="kpi-card__label"><%= t('billing:balance') %></span>
      <span class="kpi-card__icon"><span class="material-symbols-outlined">paid</span></span>
    </div>
    <div class="kpi-card__value"><%= (balance || 0).toLocaleString(locale) %></div>
    <div class="kpi-card__foot"><small><%= t('billing:credits') %></small></div>
  </div>
</div>

<div class="card tight">
  <div class="card-header">
    <div class="heading">
      <h2><%= t('billing:ledger') %></h2>
      <small><%= t('billing:ledger_help') %></small>
    </div>
  </div>
  <% if (!entries.length) { %>
    <div class="empty-state">
      <span class="material-symbols-outlined">receipt_long</span>
      <p><%= t('messages.no_records') %></p>
    </div>
  <% } else { %>
    <div class="data-table-wrap">
      <table class="data-table density-comfortable">
        <thead>
          <tr>
            <th><%= t('labels.created_at') %></th>
            <th><%= t('billing:kind.label') %></th>
            <th><%= t('billing:credits') %></th>
            <th><%= t('billing:balance_after') %></th>
            <th><%= t('billing:metadata') %></th>
          </tr>
        </thead>
        <tbody>
          <% entries.forEach(function(l){
              var meta = l.metadata || {};
              var bits = [];
              if (meta.note) bits.push(meta.note);
              if (meta.country) bits.push(meta.country);
              if (meta.durationSec) bits.push(meta.durationSec + 's');
          %>
            <tr>
              <td><small><%= new Date(l.createdAt).toLocaleString(locale) %></small></td>
              <td><span class="badge badge--neutral"><%= t('billing:kind.' + l.kind) %></span></td>
              <td><strong style="color:<%= l.credits >= 0 ? 'var(--color-success)' : 'var(--color-danger)' %>;"><%= l.credits >= 0 ? '+' : '' %><%= l.credits %></strong></td>
              <td><%= l.balanceAfter %></td>
              <td><small><%= bits.join(' · ') %></small></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</div>

<%- include('../partials/footer') %>
